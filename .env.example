# AlignME Application Environment Configuration

# ===============================
# DATABASE CONFIGURATION
# ===============================

# PostgreSQL Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/alignme

# Alternative individual database settings (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alignme
DB_USER=username
DB_PASSWORD=password

# Database pool settings
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ===============================
# APPLICATION CONFIGURATION
# ===============================

# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production

# ===============================
# SECURITY CONFIGURATION
# ===============================

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Password Security
BCRYPT_ROUNDS=12

# ===============================
# LOGGING CONFIGURATION
# ===============================

# Log Levels: error, warn, info, debug
LOG_LEVEL=info

# Log File Paths
LOG_DIR=./logs
ERROR_LOG_FILE=error.log
COMBINED_LOG_FILE=combined.log

# ===============================
# EMAIL CONFIGURATION (Optional)
# ===============================

# SMTP Settings for email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email From Address
EMAIL_FROM=noreply@alignme.com

# ===============================
# FILE UPLOAD CONFIGURATION
# ===============================

# Upload directory
UPLOAD_DIR=./uploads

# Max file sizes in MB
MAX_PROFILE_PICTURE_SIZE_MB=5
MAX_RESUME_SIZE_MB=10
MAX_COMPANY_LOGO_SIZE_MB=3
MAX_DOCUMENT_SIZE_MB=20

# Allowed file MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
ALLOWED_RESUME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# ===============================
# REDIS CONFIGURATION (Optional)
# ===============================

# Redis for caching and sessions
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===============================
# EXTERNAL API CONFIGURATION
# ===============================

# Google Maps API (for location features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# LinkedIn API (for profile import)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ===============================
# DEVELOPMENT CONFIGURATION
# ===============================

# Development Tools
DEBUG=alignme:*
ENABLE_API_DOCS=true

# Mock/Test Settings
ENABLE_MOCK_DATA=true
MOCK_EMAIL_DELIVERY=true
