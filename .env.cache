# AlignME Redis Cache Configuration
# Environment variables for Redis caching system

# =============================================================================
# REDIS CONNECTION SETTINGS
# =============================================================================

# Redis server connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# Redis connection options
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_RETRY_DELAY_ON_FAILOVER=100

# Redis key prefix for AlignME
REDIS_KEY_PREFIX=alignme:

# =============================================================================
# CACHE TTL SETTINGS (in seconds)
# =============================================================================

# Short-term cache (5 minutes) - for frequently changing data
CACHE_TTL_SHORT=300

# Medium-term cache (30 minutes) - for moderately stable data
CACHE_TTL_MEDIUM=1800

# Long-term cache (2 hours) - for stable data
CACHE_TTL_LONG=7200

# Extended cache (24 hours) - for reference data
CACHE_TTL_EXTENDED=86400

# =============================================================================
# CACHE BEHAVIOR SETTINGS
# =============================================================================

# Enable/disable cache features
CACHE_ENABLED=true
CACHE_METRICS_ENABLED=true
CACHE_HEALTH_CHECKS_ENABLED=true
CACHE_AUTO_INVALIDATION_ENABLED=true

# Cache warming settings
CACHE_WARMING_ENABLED=true
CACHE_WARMING_INITIAL_DELAY=5000
CACHE_WARMING_INTERVAL=3600000

# Cache cleanup settings
CACHE_CLEANUP_ENABLED=true
CACHE_CLEANUP_INTERVAL=14400000

# Metrics collection interval (1 minute)
CACHE_METRICS_INTERVAL=60000

# =============================================================================
# CACHE SIZE LIMITS
# =============================================================================

# Memory cache fallback settings (when Redis is unavailable)
MEMORY_CACHE_MAX_SIZE=5000
MEMORY_CACHE_DEFAULT_TTL=300000

# Redis memory limits (optional - configure in Redis server)
# REDIS_MAXMEMORY=1gb
# REDIS_MAXMEMORY_POLICY=allkeys-lru

# =============================================================================
# CACHE INVALIDATION SETTINGS
# =============================================================================

# Event-driven invalidation
CACHE_EVENT_INVALIDATION_ENABLED=true

# Time-based invalidation
CACHE_TIME_INVALIDATION_ENABLED=true

# Bulk invalidation batch size
CACHE_BULK_INVALIDATION_BATCH_SIZE=100

# =============================================================================
# LOGGING AND MONITORING
# =============================================================================

# Cache logging level (debug, info, warn, error)
CACHE_LOG_LEVEL=info

# Enable cache operation logging
CACHE_OPERATION_LOGGING=true

# Enable cache statistics logging
CACHE_STATS_LOGGING=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Require admin role for cache management endpoints
CACHE_ADMIN_REQUIRED=true

# Enable cache operation audit logging
CACHE_AUDIT_LOGGING=true

# =============================================================================
# DEVELOPMENT/TESTING SETTINGS
# =============================================================================

# Enable cache debugging in development
CACHE_DEBUG_MODE=false

# Skip cache in development (for testing)
CACHE_SKIP_IN_DEV=false

# Enable cache warming in development
CACHE_WARM_IN_DEV=true

# =============================================================================
# PRODUCTION OPTIMIZATIONS
# =============================================================================

# Enable compression for cached data
CACHE_COMPRESSION_ENABLED=false

# Enable cache serialization optimization
CACHE_SERIALIZATION_OPTIMIZED=true

# Enable cache key optimization
CACHE_KEY_OPTIMIZATION=true

# Connection pooling for high-traffic scenarios
REDIS_CONNECTION_POOL_SIZE=10

# =============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT ENVIRONMENTS
# =============================================================================

# Development Environment
# REDIS_HOST=localhost
# REDIS_PORT=6379
# CACHE_TTL_SHORT=60
# CACHE_DEBUG_MODE=true

# Staging Environment
# REDIS_HOST=redis-staging.alignme.com
# REDIS_PORT=6379
# REDIS_PASSWORD=staging_password
# CACHE_TTL_SHORT=300

# Production Environment
# REDIS_HOST=redis-prod.alignme.com
# REDIS_PORT=6379
# REDIS_PASSWORD=production_password
# REDIS_DB=0
# CACHE_COMPRESSION_ENABLED=true
# REDIS_CONNECTION_POOL_SIZE=20
