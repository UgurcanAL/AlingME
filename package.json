{
  "name": "alignme-app",
  "version": "1.0.0",
  "description": "AlignME - Professional networking and job matching platform with TARDIS-inspired UI",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
  "start": "node dist/server.js",
  "start:enhanced": "node dist/server-enhanced.js",
  "start:new": "node dist/src/startup.js",
  "dev": "tsx --watch server.js",
  "dev:enhanced": "tsx --watch server-enhanced.js",
  "dev:watch": "nodemon --watch src --ext ts,js --exec tsx server.js",
    "dev:docker": "docker-compose up --build",
    "dev:docker:down": "docker-compose down",
  "build": "node ./scripts/build.mjs && npm run optimize",
  "build:production": "cross-env NODE_ENV=production npm run build",
  "compile": "tsc -p tsconfig.json",
    "optimize": "echo 'Optimization step completed'",
    "compress-assets": "echo 'Asset compression completed'",
  "test": "jest",
    "test:unit": "node src/tests/testRunner.js unit",
    "test:integration": "node src/tests/testRunner.js integration",
    "test:collaboration": "node src/tests/testRunner.js collaboration",
    "test:portfolio": "node src/tests/testRunner.js portfolio",
    "test:config": "node tests/config-validation.test.js",
    "test:watch": "node src/tests/testRunner.js watch",
    "test:coverage": "node src/tests/testRunner.js coverage",
    "test:help": "node src/tests/testRunner.js help",
    "test:docker": "docker-compose --profile testing run --rm test-runner npm test",
  "jest": "jest",
  "jest:security": "jest -c jest.security.config.js",
    "jest:watch": "jest --watch",
    "jest:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:security": "eslint . --config .eslintrc.security.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "docs": "node swagger.js",
    "generate:openapi": "node generate-openapi.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed:all": "npx sequelize-cli db:seed:all",
    "db:seed:undo:all": "npx sequelize-cli db:seed:undo:all",
    "config:validate": "node tests/config-validation.test.js",
    "config:health": "curl http://localhost:3000/health/config",
    "monitoring:health": "curl http://localhost:3000/api/monitoring/health",
    "monitoring:metrics": "curl http://localhost:3000/api/monitoring/metrics",
    "monitoring:performance": "curl http://localhost:3000/api/monitoring/performance",
    "monitoring:test": "curl -X POST http://localhost:3000/api/monitoring/test/log-levels",
    "logs:view": "tail -f logs/combined.log",
    "logs:errors": "tail -f logs/error.log",
    "logs:performance": "tail -f logs/performance.log",
    "logs:business": "tail -f logs/business.log",
    "docker:build": "docker build -t alignme:latest .",
    "docker:build:prod": "docker build -f Dockerfile.production -t alignme:production .",
    "docker:run": "docker run -p 3000:3000 alignme:latest",
    "docker:run:prod": "docker run -p 3000:3000 alignme:production",
    "docker:dev": "./scripts/docker-dev.sh up",
    "docker:dev:build": "./scripts/docker-dev.sh up --build",
    "docker:dev:down": "./scripts/docker-dev.sh down",
    "docker:dev:logs": "./scripts/docker-dev.sh logs",
    "docker:dev:shell": "./scripts/docker-dev.sh shell",
    "docker:dev:clean": "./scripts/docker-dev.sh clean",
    "docker:dev:status": "./scripts/docker-dev.sh status",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:scan": "npm run lint:security && npm run security:audit",
    "ci:test": "npm run lint && npm run type-check && npm run test",
    "ci:build": "npm run build:production",
    "ci:security": "npm run security:scan",
    "deploy:dev": "echo 'Development deployment would run here'",
    "deploy:staging": "echo 'Staging deployment would run here'",
    "deploy:prod": "echo 'Production deployment would run here'",
    "health:check": "curl -f http://localhost:3000/health || exit 1",
    "performance:test": "echo 'Performance tests would run here'"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.850.0",
    "@aws-sdk/client-s3": "^3.850.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "express-slow-down": "^2.1.0",
    "express-timeout-handler": "^2.2.2",
    "express-validator": "^7.2.1",
    "form-data": "^4.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "juice": "^11.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.5",
    "opossum": "^9.0.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "redis": "^5.6.1",
    "sanitize-html": "^2.17.0",
    "sequelize": "^6.33.0",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "validator": "^13.15.15",
    "winston": "^3.17.0",
    "ws": "^8.18.3",
    "xss": "^1.0.15",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-fileupload": "^1.5.1",
    "@types/helmet": "^0.0.48",
    "@types/hpp": "^0.2.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.17",
    "@types/sanitize-html": "^2.16.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "audit-ci": "^7.1.0",
    "babel-jest": "^29.7.0",
    "bundlesize": "^0.18.1",
    "eslint": "^9.31.0",
    "eslint-plugin-security": "^3.0.1",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
  "cross-env": "^7.0.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2",
    "sequelize-cli": "^6.6.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
