# Development Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (Update with your PostgreSQL credentials)
DATABASE_URL=postgresql://postgres:password@localhost:5432/alignme
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alignme
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-for-development-minimum-32-chars
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-for-development-minimum-32-chars

# Email Configuration
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=ethereal.user@ethereal.email
EMAIL_PASS=ethereal.pass
EMAIL_FROM=noreply@alignme.com
EMAIL_SERVICE=ethereal
SUPPORT_EMAIL=support@alignme.com
BASE_URL=http://localhost:3000

# SMTP Configuration
SMTP_HOST=smtp.ethereal.email
SMTP_USER=ethereal.user@ethereal.email
SMTP_PASS=ethereal.pass

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Google Configuration
GOOGLE_MAPS_API_KEY=placeholder-key
GOOGLE_CLIENT_ID=placeholder-google-client-id
GOOGLE_CLIENT_SECRET=placeholder-google-client-secret

# Application Features
ENABLE_CORS_DEBUG=false
ENABLE_SQL_LOGGING=false
ENABLE_SWAGGER=true

# Logging
LOG_LEVEL=info

# Server Configuration
HOST=localhost

# ── Gemini AI Configuration ──────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
