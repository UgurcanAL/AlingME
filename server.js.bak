import express from 'express';
import path from 'path';
import { fileURLToPath } from 'url';
import fs from 'fs';
import swaggerUi from 'swagger-ui-express';
import helmet from 'helmet';
import environmentConfig from './config/environment.js';
import { swaggerSpec, swaggerUiOptions } from './src/config/swagger.js';
import apiRoutes from './routes/api.js';
import userRoutes from './routes/users.js';
import aiMatchingRoutes from './src/routes/aiMatching.js';
// Phase 10 security modules
import securityRoutes from './src/routes/security.js';
// Use the TypeScript middleware directly in dev via tsx
import { securityMiddleware } from './src/middleware/security.ts';
import { errorBoundary, notFoundHandler, errorHandler } from './src/middleware/errorHandler.js';
// Import new secure routes - Comment out for now since they may not be compiled
// import portfolioRoutes from './src/routes/portfolios.js';
// import projectRoutes from './src/routes/projects.js';

// Initialize environment configuration
console.log('🚀 Initializing AlignME Environment Configuration...');
await environmentConfig.initialize();
const config = environmentConfig.getConfig();

const app = express();
const port = config.PORT || 3000;

// Set security-related HTTP headers
app.use(helmet());

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Middleware to parse JSON bodies
app.use(express.json());

// Phase 10: Global security middleware & sync error boundary
app.use(securityMiddleware);
app.use(errorBoundary);

// Set EJS as the templating engine
app.set('view engine', 'ejs');
app.set('views', path.join(__dirname, 'views'));

// Serve static files from the 'public' directory
app.use(express.static(path.join(__dirname, 'public')));

// API routes
app.use('/api', apiRoutes);
app.use('/api/users', userRoutes);
app.use('/api/ai-matching', aiMatchingRoutes);
// Phase 10: Security routes
app.use('/api/security', securityRoutes);

// Secure portfolio and project routes - Comment out until TypeScript is compiled
// app.use('/api/portfolios', portfolioRoutes);
// app.use('/api/projects', projectRoutes);

// API Docs with enhanced styling and features
app.use('/api-docs', swaggerUi.serve, swaggerUi.setup(swaggerSpec, swaggerUiOptions));

// API Testing Interface
app.get('/api-testing', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'api-testing.html'));
});

// Define a reusable function to render pages
const renderPage = (req, res, pageName, title) => {
  res.render(pageName, {
    title: title,
  });
};

// Route for the main page
app.get('/', (req, res) => {
  renderPage(req, res, 'home', 'Welcome to AlignME');
});

// Dynamically create routes for all .ejs files in the views directory
const viewsDir = path.join(__dirname, 'views');

fs.readdirSync(viewsDir).forEach((file) => {
  if (file.endsWith('.ejs')) {
    const pageName = path.basename(file, '.ejs');
    // Skip partials
    if (pageName.startsWith('_')) {
      return;
    }

    const routePath = `/${pageName}`;
    const pageTitle = `${pageName.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase())}`;

    app.get(routePath, (req, res) => {
      renderPage(req, res, pageName, pageTitle);
    });
  }
});

// Configuration health check endpoint
app.get('/health/config', (req, res) => {
  try {
    const healthStatus = {
      status: 'healthy',
      environment: config.NODE_ENV,
      timestamp: new Date().toISOString(),
      configuration: {
        database: {
          host: config.DB_HOST,
          port: config.DB_PORT,
          name: config.DB_NAME,
          poolMax: config.DB_POOL_MAX
        },
        server: {
          port: config.PORT,
          logLevel: config.LOG_LEVEL
        },
        features: {
          apiDocs: config.ENABLE_API_DOCS,
          mockData: config.ENABLE_MOCK_DATA,
          mockEmail: config.MOCK_EMAIL_DELIVERY
        },
        security: {
          jwtExpiresIn: config.JWT_EXPIRES_IN,
          bcryptRounds: config.BCRYPT_ROUNDS,
          rateLimitMax: config.RATE_LIMIT_MAX
        }
      }
    };
    
    res.json(healthStatus);
  } catch (error) {
    const errorMessage = error instanceof Error ? error.message : 'Unknown configuration error';
    res.status(500).json({
      status: 'unhealthy',
      error: errorMessage,
      timestamp: new Date().toISOString()
    });
  }
});

// Phase 10: Standardized 404 and error handling
app.use(notFoundHandler);
app.use(errorHandler);

app.listen(port, () => {
  console.log(`🚀 AlignME Server is running on http://localhost:${port}`);
  console.log(`📝 API docs available at http://localhost:${port}/api-docs`);
  console.log(`🩺 Configuration health check: http://localhost:${port}/health/config`);
  console.log(`🌍 Environment: ${config.NODE_ENV}`);
  console.log(`📊 Log Level: ${config.LOG_LEVEL}`);
});
